{
  "name": "getting-started",
  "version": "1.0.0",
  "description": "Discord example app",
  "main": "app/app.ts",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "tsx app/app.ts",
    "register": "tsx app/commands.ts",
    "dev": "nodemon --watch app --ext ts --exec tsx app/app.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "author": "Huy",
  "license": "MIT",
  "dependencies": {
    "discord-interactions": "^3.2.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.3",
    "tsx": "^4.20.6",
    "types": "^0.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "keywords": []
}
